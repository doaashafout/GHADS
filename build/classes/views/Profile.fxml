<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500" prefWidth="600" styleClass="root" stylesheets="@../styles/FormStyle.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ProfileController">

    <top>
        <AnchorPane>
            <MenuBar fx:id="menubar" styleClass="menu-bar" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                <menus>
                    <Menu text="File"><items><MenuItem fx:id="exit" onAction="#exitHandle" text="Exit" /></items></Menu>
                    <Menu text="Format">
                        <items>
                            <Menu text="Font Size">
                                <items>
                                    <RadioMenuItem text="Small"><toggleGroup><ToggleGroup fx:id="tg" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem selected="true" text="Medium" toggleGroup="$tg" />
                                    <RadioMenuItem text="Large" toggleGroup="$tg" />
                                </items>
                            </Menu>
                            <Menu text="Font Family">
                                <items>
                                    <RadioMenuItem selected="true" text="Arial"><toggleGroup><ToggleGroup fx:id="tg2" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem text="Times New Roman" toggleGroup="$tg2" />
                                </items>
                            </Menu>
                        </items>
                    </Menu>
                    <Menu text="Help"><items><MenuItem fx:id="about" onAction="#aboutHandle" text="About App" /></items></Menu>
                </menus>
            </MenuBar>
        </AnchorPane>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="20" maxWidth="500">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>

            <Label styleClass="section-title" text="My Profile" />

            <Separator />

            <Label styleClass="field-label" text="Full Name" />
            <TextField fx:id="fullNameField" styleClass="input" />

            <Label styleClass="field-label" text="Username" />
            <TextField fx:id="usernameField" styleClass="input" />

            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="emailField" styleClass="input" />

            <Label styleClass="field-label" text="Role" />
            <TextField fx:id="roleField" editable="false" styleClass="input" />

            <Label styleClass="field-label" text="Organization ID" />
            <TextField fx:id="orgField" editable="false" styleClass="input" />

            <Separator />

            <HBox spacing="10">
                <Button fx:id="editButton" onAction="#editHandle" styleClass="btn-primary" text="Edit" />
                <Button fx:id="saveButton" disable="true" onAction="#saveHandle" styleClass="btn-success" text="Save" />
                <Button fx:id="backButton" onAction="#backHandle" styleClass="btn-nav" text="Back" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
