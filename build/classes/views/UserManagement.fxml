<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="900" styleClass="root" stylesheets="@../styles/FormStyle.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UserController">

    <top>
        <AnchorPane>
            <MenuBar fx:id="menubar" styleClass="menu-bar" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                <menus>
                    <Menu text="File"><items><MenuItem fx:id="exit" onAction="#exitHandle" text="Exit" /></items></Menu>
                    <Menu text="Format">
                        <items>
                            <Menu text="Font Size">
                                <items>
                                    <RadioMenuItem text="Small"><toggleGroup><ToggleGroup fx:id="tg" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem selected="true" text="Medium" toggleGroup="$tg" />
                                    <RadioMenuItem text="Large" toggleGroup="$tg" />
                                </items>
                            </Menu>
                            <Menu text="Font Family">
                                <items>
                                    <RadioMenuItem selected="true" text="Arial"><toggleGroup><ToggleGroup fx:id="tg2" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem text="Times New Roman" toggleGroup="$tg2" />
                                </items>
                            </Menu>
                        </items>
                    </Menu>
                    <Menu text="Help"><items><MenuItem fx:id="about" onAction="#aboutHandle" text="About App" /></items></Menu>
                </menus>
            </MenuBar>
        </AnchorPane>
    </top>

    <left>
        <VBox spacing="15" styleClass="sidebar" prefWidth="300">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <Label styleClass="section-label" text="USER MANAGEMENT" />

            <Separator />

            <Label styleClass="field-label" text="Full Name" />
            <TextField fx:id="fullNameField" promptText="Full name" styleClass="input" />

            <Label styleClass="field-label" text="Username" />
            <TextField fx:id="usernameField" promptText="Username" styleClass="input" />

            <Label styleClass="field-label" text="Email" />
            <TextField fx:id="emailField" promptText="Email address" styleClass="input" />

            <Label styleClass="field-label" text="Password (min 8 chars)" />
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="input" />

            <Label styleClass="field-label" text="Role" />
            <ComboBox fx:id="roleCombo" promptText="Select role" styleClass="input" />

            <Label styleClass="field-label" text="Organization" />
            <ComboBox fx:id="orgCombo" promptText="Select org" styleClass="input" />

            <Separator />

            <HBox spacing="8">
                <Button fx:id="addButton" onAction="#addHandle" styleClass="btn-primary" text="Add" />
                <Button fx:id="updateButton" onAction="#updateHandle" styleClass="btn-success" text="Update" />
                <Button fx:id="deleteButton" onAction="#deleteHandle" styleClass="btn-danger" text="Delete" />
            </HBox>

            <HBox spacing="8">
                <Button fx:id="resetButton" onAction="#resetHandle" styleClass="btn-secondary" text="Reset" />
                <Button fx:id="refreshButton" onAction="#refreshHandle" styleClass="btn-outline" text="Refresh" />
                <Button fx:id="backButton" onAction="#backHandle" styleClass="btn-nav" text="Back" />
            </HBox>

        </VBox>
    </left>

    <center>
        <TableView fx:id="table" styleClass="custom-table">
            <columns>
                <TableColumn fx:id="userIdTC" prefWidth="60" text="ID" />
                <TableColumn fx:id="usernameTC" prefWidth="120" text="Username" />
                <TableColumn fx:id="fullNameTC" prefWidth="150" text="Full Name" />
                <TableColumn fx:id="emailTC" prefWidth="180" text="Email" />
                <TableColumn fx:id="roleTC" prefWidth="100" text="Role" />
            </columns>
        </TableView>
    </center>

</BorderPane>
