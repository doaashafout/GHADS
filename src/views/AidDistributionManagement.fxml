<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="900" styleClass="root" stylesheets="@../styles/FormStyle.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AidDistributionController">

    <top>
        <AnchorPane>
            <MenuBar fx:id="menubar" styleClass="menu-bar" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                <menus>
                    <Menu text="File"><items><MenuItem fx:id="exit" onAction="#exitHandle" text="Exit" /></items></Menu>
                    <Menu text="Format">
                        <items>
                            <Menu text="Font Size">
                                <items>
                                    <RadioMenuItem text="Small"><toggleGroup><ToggleGroup fx:id="tg" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem selected="true" text="Medium" toggleGroup="$tg" />
                                    <RadioMenuItem text="Large" toggleGroup="$tg" />
                                </items>
                            </Menu>
                            <Menu text="Font Family">
                                <items>
                                    <RadioMenuItem selected="true" text="Arial"><toggleGroup><ToggleGroup fx:id="tg2" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem text="Times New Roman" toggleGroup="$tg2" />
                                </items>
                            </Menu>
                        </items>
                    </Menu>
                    <Menu text="Help"><items><MenuItem fx:id="about" onAction="#aboutHandle" text="About App" /></items></Menu>
                </menus>
            </MenuBar>
        </AnchorPane>
    </top>

    <left>
        <VBox spacing="15" styleClass="sidebar" prefWidth="280">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <Label styleClass="section-label" text="AID DISTRIBUTIONS" />

            <Separator />

            <Label styleClass="field-label" text="Filter by Organization" />
            <ComboBox fx:id="filterOrgCombo" promptText="Select org..." styleClass="input" />

            <HBox spacing="8">
                <Button fx:id="filterButton" onAction="#filterHandle" styleClass="btn-primary" text="Filter" />
                <Button fx:id="showAllButton" onAction="#showAllHandle" styleClass="btn-secondary" text="Show All" />
            </HBox>

            <Separator />

            <Button fx:id="deleteButton" onAction="#deleteHandle" disable="true" styleClass="btn-danger" text="Delete Selected" />

            <Separator />

            <Button fx:id="refreshButton" onAction="#refreshHandle" styleClass="btn-outline" text="Refresh" />
            <Button fx:id="backButton" onAction="#backHandle" styleClass="btn-nav" text="Back to Dashboard" />

        </VBox>
    </left>

    <center>
        <TableView fx:id="table" styleClass="custom-table">
            <columns>
                <TableColumn fx:id="distIdTC" prefWidth="60" text="ID" />
                <TableColumn fx:id="familyNameTC" prefWidth="180" text="Family" />
                <TableColumn fx:id="orgNameTC" prefWidth="180" text="Organization" />
                <TableColumn fx:id="dateTC" prefWidth="120" text="Date" />
                <TableColumn fx:id="aidTypeTC" prefWidth="120" text="Aid Type" />
            </columns>
        </TableView>
    </center>

</BorderPane>
