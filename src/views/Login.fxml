<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" styleClass="login-root" stylesheets="@../styles/LoginStyle.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">

    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <Label styleClass="login-title" text="GHADS">
        <font>
            <Font name="Arial Black" size="36" />
        </font>
    </Label>

    <Label styleClass="login-subtitle" text="Gaza Humanitarian Aid Distribution System" />

    <VBox spacing="15" styleClass="login-form">
        <Label styleClass="field-label" text="Username" />
        <TextField fx:id="usernameField" promptText="Enter username" styleClass="input-field" />

        <Label styleClass="field-label" text="Password" />
        <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="input-field" />

        <Button fx:id="loginButton" onAction="#loginHandle" prefHeight="40" prefWidth="250" styleClass="btn-primary" text="Login" />

        <Button fx:id="exitButton" onAction="#exitHandle" prefHeight="40" prefWidth="250" styleClass="btn-secondary" text="Exit" />
    </VBox>

</VBox>
