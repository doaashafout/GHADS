<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.RadioMenuItem?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600" prefWidth="900" styleClass="root" stylesheets="@../styles/DashboardStyle.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CoordinatorDashboardController">

    <top>
        <AnchorPane>
            <MenuBar fx:id="menubar" styleClass="menu-bar" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
                <menus>
                    <Menu text="File">
                        <items>
                            <MenuItem fx:id="exit" onAction="#exitHandle" text="Exit" />
                        </items>
                    </Menu>
                    <Menu text="Format">
                        <items>
                            <Menu text="Font Size">
                                <items>
                                    <RadioMenuItem text="Small"><toggleGroup><ToggleGroup fx:id="tg" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem selected="true" text="Medium" toggleGroup="$tg" />
                                    <RadioMenuItem text="Large" toggleGroup="$tg" />
                                </items>
                            </Menu>
                            <Menu text="Font Family">
                                <items>
                                    <RadioMenuItem selected="true" text="Arial"><toggleGroup><ToggleGroup fx:id="tg2" /></toggleGroup></RadioMenuItem>
                                    <RadioMenuItem text="Times New Roman" toggleGroup="$tg2" />
                                </items>
                            </Menu>
                        </items>
                    </Menu>
                    <Menu text="Help">
                        <items>
                            <MenuItem fx:id="about" onAction="#aboutHandle" text="About App" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
        </AnchorPane>
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="25" styleClass="content-area">
            <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>

            <Label fx:id="welcomeLabel" styleClass="welcome-text" text="Welcome!">
                <font><Font name="Arial Bold" size="22" /></font>
            </Label>

            <Label styleClass="section-title" text="Organization Dashboard" />

            <HBox alignment="CENTER" spacing="20">
                <VBox alignment="CENTER" spacing="10" styleClass="stat-card">
                    <Label styleClass="stat-number" fx:id="totalFamiliesLabel" text="0" />
                    <Label styleClass="stat-label" text="Total Families" />
                </VBox>
                <VBox alignment="CENTER" spacing="10" styleClass="stat-card">
                    <Label styleClass="stat-number" fx:id="servedLabel" text="0" />
                    <Label styleClass="stat-label" text="Served By Us" />
                </VBox>
                <VBox alignment="CENTER" spacing="10" styleClass="stat-card">
                    <Label styleClass="stat-number" fx:id="notServedLabel" text="0" />
                    <Label styleClass="stat-label" text="Not Yet Served" />
                </VBox>
            </HBox>

            <Label styleClass="section-title" text="Actions" />

            <HBox alignment="CENTER" spacing="15">
                <Button onAction="#profileHandle" prefHeight="50" prefWidth="160" styleClass="btn-nav" text="My Profile" />
                <Button onAction="#familyRegistrationHandle" prefHeight="50" prefWidth="160" styleClass="btn-nav" text="Register Family" />
                <Button onAction="#aidDistributionHandle" prefHeight="50" prefWidth="160" styleClass="btn-nav" text="Aid Distribution" />
            </HBox>

            <HBox alignment="CENTER" spacing="15">
                <Button onAction="#changePasswordHandle" prefHeight="40" prefWidth="160" styleClass="btn-secondary" text="Change Password" />
                <Button onAction="#logoutHandle" prefHeight="40" prefWidth="160" styleClass="btn-danger" text="Logout" />
            </HBox>

        </VBox>
    </center>

</BorderPane>
